{
  "name": "testrails-backend",
  "version": "1.0.0",
  "description": "Backend API for TestRails clone",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=1536' tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "db:setup:test": "./scripts/setup-test-db.sh",
    "prisma:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "testrails",
    "testing",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/csrf-protection": "^6.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^8.3.1",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^5.19.1",
    "@types/ws": "^8.18.1",
    "adm-zip": "^0.5.17",
    "argon2": "^0.40.3",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.1",
    "pdfkit": "^0.18.0",
    "playwright": "^1.48.0",
    "ssh2": "^1.17.0",
    "winston": "^3.14.2",
    "ws": "^8.20.0",
    "zod": "^3.23.8",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.4.2",
    "@types/pdfkit": "^0.17.5",
    "@types/ssh2": "^1.15.5",
    "@types/zxcvbn": "^4.4.5",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "prisma": "^5.19.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.5"
  }
}
